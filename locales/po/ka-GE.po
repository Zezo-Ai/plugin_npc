msgstr "ინფორმაცის სერვისის/ჰოსტის შესახებ"

#: setup.php:286
msgid "Command Execution"
msgstr "ბრძანების შესრულება"

#: setup.php:1682
msgid "General Settings"
msgstr "ზოგადი პარამეტრები"

#: setup.php:1686
msgid "Remote Commands"
msgstr "დაშორებული ბრძანებები"

#: setup.php:1687
msgid "Allow commands to be written to the Nagios command file."
msgstr "Nagios-ის ბრძანებების ფაილში ბრძანებების ჩაწერის დაშვება."

#: setup.php:1691
msgid "Nagios Command File Path"
msgstr "Nagios-ის ბრძანების ფაილის ბილიკი"

#: setup.php:1692
msgid "The path to the Nagios command file (nagios.cmd)."
msgstr "ბილიკი Nagios-ის ბრძანების ფაილამდე (nagios.cmd)."

#: setup.php:1697
msgid "Nagios URL"
msgstr "Nagios-ის URL"

#: setup.php:1698
msgid "The full URL to your Nagios installation (http://nagios.company.com/nagios/)"
msgstr "ბმული თქვენს Nagios-მდე (http://nagios.company.com/nagios/)"

#: setup.php:1703
msgid "Date Format"
msgstr "თარიღის ფორმატი"

#: setup.php:1704
msgid "Select the format you want for displaying dates."
msgstr "აირჩიეთ ფორმატი, რომელშიც თარიღის ჩვენება გნებავთ."

#: setup.php:1710
msgid "Time Format"
msgstr "დროის ფორმატი"

#: setup.php:1711
msgid "Select the format you want for displaying times."
msgstr "აირჩიეთ ფორმატი დროის საჩვენებლად."

#: setup.php:1717
msgid "Portlet Refresh Rate"
msgstr "პორტლეტის განახლების სიხშირე"

#: setup.php:1718
msgid "The amount of time in seconds to wait before the portlets refresh. The minimum is 30 seconds."
msgstr "დრო წამებში, რომელიც უნდა გავა, სანამ პორტლეტები განახლდება. მინიმალური დროა 30 წამი."

#: setup.php:1724
msgid "Host/Service Config Type"
msgstr "ჰოსტის/სერვისის კონფიგურაციის ტიპი"

#: setup.php:1725
msgid "The config type is based on whether or not you are restoring retained information when Nagios starts. If you are unsure just leave the default value. If you can see host and service groups but not hosts or services try changing this setting."
msgstr "კონფიგურაციის ტიპი ეყრდნობა, ახდენთ თუ არა შენარჩუნებული ინფორმაციის აღდგენას Nagios-ის გაშვებისას. თუ დარწმუნებული არ ბრძანდებით, უბრალოდ დატოვეთ ნაგულისხმევი მნიშვნელობა. თუ ხედავთ ჰოსტების და სერვისის ჯგუფებს, მაგრამ არა ჰოსტებს ან სერვისებს, სცადეთ, ეს პარამეტრი შეცვალოთ."

#: setup.php:1731
msgid "Host Icons"
msgstr "ჰოსტის ხატულები"

#: setup.php:1732
msgid "Enable displaying host icons in the hosts grid. The icon_image and icon_image_alt parameters of the Nagios host definition are used to set the image. Icons should be 16x16 to get the best look. this setting does not affect the host status icons."
msgstr "ჰოსტის ხატულების ჩვენების ჩართვა ჰოსტების ბადეზე. პარამეტრები icon_image და icon_image_alt Nagios-ის ჰოსტის აღწერაში გამოიყენება გამოსახულების დასაყენებლად. ხატულები უნდა იყოს 16x16 ზომის. ამ პარამეტრს არ აქვს გავლენა ჰოსტის სტატუსის ხატულებზე."

#: setup.php:1736
msgid "Service Icons"
msgstr "სერვისის ხატულები"

#: setup.php:1737
msgid "Enable displaying service icons in the services grid. The icon_image and icon_image_alt parameters of the Nagios service definition are used to set the image. Icons should be 16x16 to get the best look. This setting does not affect the service status icons."
msgstr "ჩართავს სერვისის ხატულების ჩვენებას სერვისების ბადეზე. Nagios-ის სერვისის აღწერაში icon_image და icon_image_alt გამოიყენება გამოსახულების დასაყენებლად. ხატულები უნდა იყოს 16x16 ზომით. ამ პარამეტრს არ აქვს გავლენა სერვისის სტატუსის ხატულებზე."

#: setup.php:1741
msgid "Logging"
msgstr "ჟურნალი"

#: setup.php:1745
msgid "Logging Level"
msgstr "ჟურნალის დონე"

#: setup.php:1746
msgid "The level of detail you want sent to the Cacti log file. WARNING: Leaving in DEBUG will quickly fill the cacti log."
msgstr "დეტალების დონე, რომელიც გნებავთ, Cacti-ის ჟურნალში ჩაწეროთ. გაფრთხილება: თუ დატოვებთ გამართვის დონეზე, cacti-ის ჟურნალი მალევე გადაივსება."
